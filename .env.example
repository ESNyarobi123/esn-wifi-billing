# =============================================================================
# ESN WiFi Billing — monorepo environment
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=esn
POSTGRES_PASSWORD=esn_dev_change_me
POSTGRES_DB=esn_wifi
# From host machine (local dev without Docker for API):
DATABASE_URL=postgresql+asyncpg://esn:esn_dev_change_me@localhost:5432/esn_wifi
# From Docker Compose API container use:
# DATABASE_URL=postgresql+asyncpg://esn:esn_dev_change_me@postgres:5432/esn_wifi

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
# Required to create routers (encrypts API password in DB). Generate once: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ROUTER_CREDENTIALS_FERNET_KEY=

# app.seed: false/unset = minimal bootstrap (admin + site hq, no sample rows). true = full demo dataset.
SEED_DEMO_DATA=false

# Include every browser origin that loads the admin UI (comma-separated).
# localhost ≠ 127.0.0.1 for CORS — list both if you use either in the address bar.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Comma-separated; empty disables TrustedHostMiddleware
TRUSTED_HOSTS=

# Portal rate limits (distributed when PORTAL_RATE_LIMIT_BACKEND=redis; requires REDIS_URL)
PORTAL_RATE_LIMIT_BACKEND=redis
PORTAL_RATE_LIMIT_REDIS_KEY_PREFIX=esn:rl
PORTAL_RATE_LIMIT_REDIS_FAIL_OPEN=true
PORTAL_RATE_LIMIT_REDEEM_PER_MINUTE=40
PORTAL_RATE_LIMIT_PAY_PER_MINUTE=25
PORTAL_RATE_LIMIT_STATUS_PER_MINUTE=120
PORTAL_RATE_LIMIT_REDEEM_WINDOW_SECONDS=60
PORTAL_RATE_LIMIT_PAY_WINDOW_SECONDS=60
PORTAL_RATE_LIMIT_STATUS_WINDOW_SECONDS=60
# Local single-process: PORTAL_RATE_LIMIT_BACKEND=memory

# Reconciliation: cancel pending payments older than this (hours)
PENDING_PAYMENT_ABANDON_HOURS=72

# Real MikroTik adapter (when MIKROTIK_USE_MOCK=false)
MIKROTIK_COMMAND_TIMEOUT_SECONDS=25
MIKROTIK_MAX_RETRIES=2
MIKROTIK_USE_ROUTEROS_REST_STUB=false

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Browser + Next.js server (SSR portal branding fetch): JSON API origin, no trailing slash.
# Must be reachable from the user’s browser and from the Next.js runtime that runs RSC/data fetches.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Web-only: set in Docker/runtime for the `web` container so SSR (portal branding) calls the API by
# service name, not localhost. See apps/web/docs/STAGING.md
# INTERNAL_API_URL=http://api:8000

# Web-only overrides: copy `apps/web/.env.example` to `apps/web/.env.local` if you run the UI separately.

# --- ClickPesa (optional; keep disabled for local mock payments) ---
CLICKPESA_ENABLED=false
CLICKPESA_API_BASE_URL=https://api.clickpesa.com
CLICKPESA_CLIENT_ID=
CLICKPESA_API_KEY=
# Backward-compat alias; if set and CLICKPESA_API_KEY is empty, the API will still use it as the ClickPesa API key.
CLICKPESA_CLIENT_SECRET=
CLICKPESA_CHECKSUM_KEY=
DEFAULT_PAYMENT_PROVIDER=mock
MIKROTIK_USE_MOCK=true
