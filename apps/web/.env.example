# ESN WiFi Billing — web app (Next.js)
# Copy to `.env.local` for local development.

# Required for production/staging: public URL of the FastAPI backend (no trailing slash).
# Baked into **client** JS at `next build`. Rebuild after changing.
# Browser JSON API + default server origin if INTERNAL_API_URL is unset.
# Example: https://api.yourdomain.com
# Local default if unset: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional (server / RSC / SSR only): API origin when the Next server must reach FastAPI on a
# different hostname than browsers — e.g. Docker `http://api:8000`. Not NEXT_PUBLIC (not inlined
# into client bundles). See docs/STAGING.md
# INTERNAL_API_URL=http://api:8000

# Playwright E2E (`npm run test:e2e`): uses `build:standalone` + `start:standalone` by default.
# For dev server under automation only: PW_WEB_SERVER=dev npm run test:e2e:dev
